# Environment variables for the Streamlit app.
#
# To use: copy this file to `.env` in the same folder and fill in real
# values. NEVER commit your actual .env file (it's already in
# .gitignore) and never paste real credentials into chat, a README, or
# any file that might get committed or shared.

# ---------------------------------------------------------------------
# Database (optional -- app defaults to bundled CSVs if this section
# is left unset). See README.md's "Connect to PostgreSQL" section.
# ---------------------------------------------------------------------

# Set to true to make the app read from PostgreSQL instead of the
# bundled CSVs in data/processed/. Requires DATABASE_URL below AND
# running `python scripts/load_star_schema.py` (from the repo root) first to populate the tables.
USE_DATABASE=false

# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# Example for a local install with default settings:
# DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/job_market_db
DATABASE_URL=

# ---------------------------------------------------------------------
# Reserved for future use -- not read by any code yet
# ---------------------------------------------------------------------
# SENTRY_DSN=
# ANALYTICS_ID=

APP_ENV=development
LOG_LEVEL=INFO
