# ============================================================
# Data
# ============================================================
# Raw source datasets stay local -- survey_results_public.csv alone is
# ~160MB, over GitHub's 100MB hard limit. Document how to re-download
# raw sources in README.md instead of committing them.
data/raw/*.csv
!data/raw/.gitkeep

# Processed datasets ARE committed -- streamlit_app/config/settings.py
# points DATA_DIR at data/processed/, and the app reads these CSVs
# directly by default (USE_DATABASE=false). Without them, every page
# shows "data file not found" on Streamlit Cloud.
!data/processed/*.csv
!data/processed/.gitkeep
!data/interim/.gitkeep

# SQLite / warehouse databases -- local scratch artifacts, not read by
# the deployed app (it reads data/processed/*.csv or Postgres, never
# a .db file directly)
*.db

# Notebook-generated validation duplicates of data/processed/*.csv --
# reproduced only to prove notebook results match the pipeline output,
# not needed by the app or by anyone cloning the repo
notebooks/reports/*.csv
notebooks/reports/*.db

# ============================================================
# Environment / secrets
# ============================================================
# streamlit_app/.env holds DATABASE_URL, USE_DATABASE, etc.
.env
.env.*
!.env.example

# ============================================================
# Python
# ============================================================
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
*.egg-info/
.pytest_cache/
venv/
.venv/
env/

# ============================================================
# IDE / OS
# ============================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================================
# Power BI
# ============================================================
# .pbix not produced in this build -- see docs/technical_design_document.md
*.pbix

# ============================================================
# Logs
# ============================================================
logs/*.log
streamlit_app/logs/*.log
!streamlit_app/logs/.gitkeep

# ============================================================
# Personal / optional
# ============================================================
# A real resume PDF is personal -- if you add one to
# streamlit_app/assets/, decide for yourself whether it belongs in
# version control. Not excluded by default.